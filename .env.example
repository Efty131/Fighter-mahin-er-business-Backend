# ─── Server ───────────────────────────────────────────────
PORT=4002
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────
MONGO_URL=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/<dbname>

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=<your_jwt_secret_here>

# ─── Admin Credentials ────────────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin@1234

# ─── Cloudinary ───────────────────────────────────────────
# Get these from: https://console.cloudinary.com → Settings → API Keys
CLOUDINARY_CLOUD_NAME=dbmdtv39
CLOUDINARY_API_KEY=<your_api_key>
CLOUDINARY_API_SECRET=<your_api_secret>
CLOUDINARY_UPLOAD_FOLDER=bigtime-lms
